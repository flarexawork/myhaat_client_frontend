<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Leave real files and directories alone.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Send every other request to the SPA entry point.
  RewriteRule ^ index.html [L]
</IfModule>
